# Mongo
MONGO_URL=mongodb://localhost:27017
MONGO_DB=verification

# Fetcher service
FETCHER_PORT=8001
FETCHER_MODE=fixture          # fixture | voyager | headless | login
FIXTURES_DIR=./fixtures

# Login mode (FETCHER_MODE=login) — opens real browser, logs in with creds
LINKEDIN_EMAIL=               # your LinkedIn email
LINKEDIN_PASSWORD=            # your LinkedIn password
LINKEDIN_STATE_PATH=linkedin_state.json  # optional JSON backup from Playwright
LINKEDIN_PLAYWRIGHT_PROFILE_DIR=      # empty = .linkedin-playwright-profile next to state file
LINKEDIN_PLAYWRIGHT_CHANNEL=          # e.g. chrome — use installed Google Chrome (recommended on Mac)

# Voyager mode (FETCHER_MODE=voyager) — uses raw cookies
LINKEDIN_LI_AT=               # session cookie from a real LinkedIn login
LINKEDIN_JSESSIONID=          # CSRF source; usually ajax:1234567890
LINKEDIN_BCOOKIE=
LINKEDIN_LIDC=
LINKEDIN_DAILY_CAP=80         # hard daily request limit per account
LINKEDIN_MIN_DELAY_MS=2500    # minimum delay between requests
LINKEDIN_MAX_DELAY_MS=12000   # maximum delay between requests

# Verifier service
VERIFIER_PORT=8000
FETCHER_URL=http://localhost:8001

# LLM (only used for company disambiguation)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Cache freshness thresholds (days)
PROFILE_FRESH_DAYS=14
PROFILE_HARD_TTL_DAYS=90
COMPANY_FRESH_DAYS=60
COMPANY_HARD_TTL_DAYS=365
